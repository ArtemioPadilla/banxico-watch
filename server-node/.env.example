# server-node environment. Copy to `.env` (loaded by your process manager or
# docker-compose env_file). NONE of these are PUBLIC_ — they stay server-side.

# Port the API listens on.
PORT=8787

# <owner>/<repo> the GitHub proxy + feedback endpoints act on.
REPO_SLUG=ArtemioPadilla/inceptor

# Server-only GitHub token (repo scope for issue creation; public_repo is enough
# for public repos). Empty → /api/issues runs unauthenticated (60 req/h) and
# /api/feedback returns 503.
GITHUB_TOKEN=

# Allowed CORS origin — the static site's URL. Use the exact origin in prod.
CORS_ORIGIN=*

# Optional: forward validated form submissions to a downstream handler
# (transactional email, CRM webhook, etc.). Empty → submissions are logged only.
CONTACT_FORWARD_URL=
NEWSLETTER_FORWARD_URL=
