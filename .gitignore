# Environment secrets — never commit real secrets
.env
.env.*
# …but the committed example file must NOT be ignored (it carries no secrets)
!.env.example

# Build outputs
node_modules/
dist/
.astro/
.cache/

# Logs (any .log file — including firebase-debug.log, npm-debug.log, etc.)
*.log
logs/

# Test / CI artifacts
test-results/
playwright-report/
.lighthouseci/
coverage/

# OS / editor artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# Stray local files that sneaked into the working tree during development
image002.png
names.md
