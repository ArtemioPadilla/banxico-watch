{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/gallery/index.html",
        "http://localhost/demos/dashboard/index.html",
        "http://localhost/docs/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--headless --no-sandbox",
        "budgetsPath": "./lighthouse-budgets.json"
      }
    },
    "assert": {
      "//": "Gate on category scores (Lighthouse aggregates individual audits into these) plus Core Web Vitals. We deliberately do NOT use the lighthouse:no-pwa assertion preset — it asserts ~150 granular audits at error level, which is the wrong altitude for a CI gate. The category score already reflects those audits. CWV are warn-level: informative, not release-blocking. Measured baseline + open a11y follow-up are in docs/perf-playbook.md.",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
