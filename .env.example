# Example environment file for inceptor.
#
# Copy to `.env` for local development, or set these in your deploy host's
# env config (Cloudflare Pages, Netlify, Vercel, GitHub Actions secrets, etc.).
#
# Everything prefixed PUBLIC_ is inlined into the browser bundle at build
# time — never put real secrets here. Server-only secrets would use a
# different prefix; this scaffold has no backend yet.

# --- Build metadata ---------------------------------------------------------

# Release channel: production | preview | development
# Affects flags.channel and the Sentry sample rate.
PUBLIC_CHANNEL=development

# Build SHA + version surface on the FeedbackFAB diagnostics. CI normally
# injects these from $GITHUB_SHA and package.json; leave unset locally.
PUBLIC_BUILD_SHA=
PUBLIC_VERSION=

# --- Repo wiring ------------------------------------------------------------

# Where the FeedbackFAB files issues. `<owner>/<repo>`. Defaults to the
# template repo in dev; override per fork.
PUBLIC_REPO_SLUG=ArtemioPadilla/inceptor

# --- Feature flags ----------------------------------------------------------
# All flags accept: true / false / 1 / 0 / on / off / yes / no.
# Defaults are coded in src/lib/flags.ts.

PUBLIC_FLAG_EXPERIMENTAL_GALLERY=false
PUBLIC_FLAG_FEEDBACK_FAB=true
PUBLIC_FLAG_BLOG=true
PUBLIC_FLAG_DOCS_SEARCH=true
PUBLIC_FLAG_PWA_PROMPTS=true

# --- Self-hosted backend (opt-in, ADR 0006) ---------------------------------

# Origin of a self-hosted backend (server-node/ or server-flask/). UNSET = the
# site stays fully static: forms run in demo mode and the GitHub islands hit
# api.github.com directly (60 req/h cap). SET = forms + GitHub reads route
# through the backend (token proxy, no cap; FeedbackFAB can create real issues).
#   e.g. http://localhost:8787 (node) | http://localhost:8788 (flask docker)
# See src/lib/api.ts and server-node/README.md. The server's own secrets
# (GITHUB_TOKEN, …) live in server-*/.env, NEVER in a PUBLIC_ var.
PUBLIC_API_BASE=

# --- Contact + newsletter ---------------------------------------------------

# URL of a JSON-accepting handler (Web3Forms / Formspree / Netlify Forms /
# Cloudflare Workers — whatever you wire). Leave empty to fall back to the
# backend's /api/contact when PUBLIC_API_BASE is set, else demo mode.
PUBLIC_CONTACT_ENDPOINT=

# Buttondown / ConvertKit / any subscribe URL accepting { email }. Empty falls
# back to the backend's /api/newsletter when PUBLIC_API_BASE is set.
PUBLIC_NEWSLETTER_ENDPOINT=

# --- Error monitoring (Sentry skeleton, off by default) ---------------------

# Install @sentry/browser AND set both of these to wire real Sentry.
# Without the npm package, the skeleton in src/lib/sentry.ts falls back to
# console.error — no runtime crash.
PUBLIC_FLAG_SENTRY=false
PUBLIC_SENTRY_DSN=

# --- Analytics (skeleton, off by default) -----------------------------------

# Provider script tag injected by src/lib/analytics.ts when enabled.
# Choose plausible (default) or umami. Self-hosters: override script URL.
PUBLIC_FLAG_ANALYTICS=false
PUBLIC_ANALYTICS_PROVIDER=plausible
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_ANALYTICS_SCRIPT_URL=
