# server-flask environment. Copy to `.env` (loaded by python-dotenv on import).
# NONE of these are PUBLIC_ — they stay server-side.

PORT=8787

# <owner>/<repo> the GitHub proxy + feedback endpoints act on.
REPO_SLUG=ArtemioPadilla/inceptor

# Server-only GitHub token. Empty → /api/issues runs unauthenticated (60 req/h)
# and /api/feedback returns 503.
GITHUB_TOKEN=

# Allowed CORS origin — the static site's URL. Use the exact origin in prod.
CORS_ORIGIN=*

# Optional: forward validated form submissions downstream. Empty → logged only.
CONTACT_FORWARD_URL=
NEWSLETTER_FORWARD_URL=
