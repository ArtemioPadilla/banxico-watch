---
import { withBase } from '@/lib/href';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IssuesList from '../../components/islands/IssuesList';
---

<BaseLayout title="Data demo — inceptor" description="GitHub Issues fetcher with persisted IndexedDB cache">
  <main class="mx-auto max-w-3xl px-4 py-12 space-y-6">
    <header>
      <h1 class="text-3xl font-bold tracking-tight" style="view-transition-name: page-title">Data island demo</h1>
      <p class="mt-2 text-muted-foreground">
        Live open issues for this template's GitHub repo. Cached to IndexedDB
        on first load — refresh to see the cache render before the network
        round-trip completes.
      </p>
    </header>

    <IssuesList client:visible />

    <footer class="border-t border-border pt-6 text-sm text-muted-foreground space-y-2">
      <p>
        Looking for a larger-scale demo?
        <a href={withBase('/demos/data/large/')} class="ml-1 underline underline-offset-4 hover:text-foreground">
          View the 50k-row virtualization demo →
        </a>
      </p>
      <p>
        <a
          href="https://github.com/ArtemioPadilla/inceptor/blob/main/src/pages/demos/data.astro"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-4 hover:text-foreground"
        >
          View source on GitHub ↗
        </a>
      </p>
    </footer>
  </main>
</BaseLayout>
