---
import { withBase } from '@/lib/href';
import BaseLayout from '../../layouts/BaseLayout.astro';

const demos = [
  {
    href: '/demos/dashboard/',
    name: 'Dashboard',
    summary:
      'KPIs + charts + DataTable composed on a single page, fetching live GitHub data via TanStack Query.',
    hint: 'Watch the skeletons resolve into live data; sort the Recent issues table.',
  },
  {
    href: '/demos/ai-chat/',
    name: 'AI chat',
    summary:
      'Agent-native UI kit composed: streaming chat thread, thinking state, prompt input, AI output disclosure, and response feedback wired to the issue loop.',
    hint: 'Send a message — watch the mock token-stream; thumbs-down opens a prefilled GitHub issue.',
  },
  {
    href: '/demos/data/',
    name: 'Data island',
    summary:
      'GitHub issues fetcher with loading, error, and empty states. Cache persisted to IndexedDB.',
    hint: 'Reload the page — the cache hydrates instantly from IndexedDB before the refetch lands.',
  },
  {
    href: '/demos/data/large/',
    name: '50,000-row table',
    summary:
      'DataTable scaled to 50k deterministic rows via TanStack Virtual. Sort, filter, URL state sync.',
    hint: 'Type in the filter and sort a column — input latency stays under 50 ms.',
  },
  {
    href: '/demos/settings/',
    name: 'Settings page',
    summary:
      'Tabbed settings UI composing Select, Switch rows, RadioGroup, Slider, Textarea, Avatar and a Save button with local state.',
    hint: 'Flip controls and hit Save; state is local and the toast self-dismisses.',
  },
  {
    href: '/demos/api/',
    name: 'Backend API',
    summary:
      'The opt-in self-hosted backend contract (Node/Hono + Flask/Pydantic): contact/newsletter handlers, a token-backed GitHub proxy, feedback→issue, and OpenAPI/Swagger.',
    hint: 'Static by default — set PUBLIC_API_BASE and the same forms go through the proxy.',
  },
];
---

<BaseLayout title="Demos" description="Composed real-feeling pages stitching primitives into believable products.">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-foreground" style="view-transition-name: page-title">
        Demos
      </h1>
      <p class="mt-2 text-muted-foreground">
        Composed real-feeling pages. Looking for individual primitives?
        Visit <a href={withBase('/gallery/')} class="text-primary underline underline-offset-2 hover:text-primary/80">/gallery</a>.
      </p>
    </header>

    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        demos.map((demo) => (
          <li>
            <a
              href={withBase(demo.href)}
              class="group block rounded-lg border border-border bg-card p-5 transition-colors hover:bg-accent/40"
            >
              <h2 class="text-base font-semibold text-foreground group-hover:underline">
                {demo.name}
              </h2>
              <p class="mt-2 text-sm text-muted-foreground">{demo.summary}</p>
              {demo.hint && (
                <p class="mt-3 font-mono text-[0.7rem] uppercase tracking-wide text-primary/90">
                  try: <span class="normal-case tracking-normal text-muted-foreground">{demo.hint}</span>
                </p>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <footer class="mt-10 border-t border-border pt-6 text-sm text-muted-foreground">
      <a
        href="https://github.com/ArtemioPadilla/inceptor/blob/main/src/pages/demos/index.astro"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-4 hover:text-foreground"
      >
        View source on GitHub ↗
      </a>
    </footer>
  </main>
</BaseLayout>
