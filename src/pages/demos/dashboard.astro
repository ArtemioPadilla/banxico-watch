---
import { withBase } from '@/lib/href';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DashboardIsland from '../../components/islands/DashboardIsland';
---

<BaseLayout title="Dashboard" description="Live issue & PR dashboard">
  <main class="mx-auto max-w-7xl px-4 py-12 space-y-6">
    <header>
      <h1 class="text-3xl font-bold tracking-tight" style="view-transition-name: page-title">Dashboard</h1>
      <p class="mt-2 text-muted-foreground">
        Live GitHub data for this template's own repository. KPIs +
        charts + table on a single page, hydrated as one island, cached
        via TanStack Query / idb-keyval.
      </p>
    </header>

    <!--
      client:visible hydrates the island only once it scrolls into view.
      This keeps the page fast on load — Lighthouse Perf stays high because
      the heavy React + Recharts bundle is deferred until the user actually
      sees the dashboard section.
    -->
    <DashboardIsland client:visible />

    <footer class="border-t border-border pt-6 text-sm text-muted-foreground flex flex-wrap gap-x-6 gap-y-2">
      <a
        href={withBase('/demos/')}
        class="underline underline-offset-4 hover:text-foreground"
      >
        ← Back to demos
      </a>
      <a
        href="https://github.com/ArtemioPadilla/inceptor/blob/main/src/pages/demos/dashboard.astro"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-4 hover:text-foreground"
      >
        View source (page) on GitHub ↗
      </a>
      <a
        href="https://github.com/ArtemioPadilla/inceptor/blob/main/src/components/islands/DashboardIsland.tsx"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-4 hover:text-foreground"
      >
        View source (island) on GitHub ↗
      </a>
    </footer>
  </main>
</BaseLayout>
