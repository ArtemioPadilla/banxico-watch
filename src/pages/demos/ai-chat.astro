---
import { withBase } from '@/lib/href';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AIChatDemo from '../../components/islands/AIChatDemo';
---

<BaseLayout
  title="AI chat demo — inceptor"
  description="A composed AI surface: chat thread, streaming + thinking states, prompt input, AI output disclosure, and response feedback wired to the issue loop."
>
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-12 space-y-6">
    <header>
      <h1 class="text-3xl font-bold tracking-tight" style="view-transition-name: page-title">AI chat</h1>
      <p class="mt-2 text-muted-foreground">
        The agent-native UI kit composed into one surface: a streaming chat
        thread, the &ldquo;thinking&rdquo; state, an auto-growing prompt input
        (Enter sends, Shift+Enter for a newline, Stop while generating), the
        AI output-disclosure label, and per-response feedback. Responses are a
        deterministic mock — no API key needed. A thumbs-down opens a
        pre-filled GitHub issue, closing the same feedback loop the FeedbackFAB
        uses.
      </p>
    </header>

    <AIChatDemo client:visible />

    <footer class="border-t border-border pt-6 text-sm text-muted-foreground flex flex-wrap gap-x-6 gap-y-2">
      <a href={withBase('/demos/')} class="underline underline-offset-4 hover:text-foreground">← All demos</a>
      <a
        href="https://github.com/ArtemioPadilla/inceptor/blob/main/src/components/islands/AIChatDemo.tsx"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-4 hover:text-foreground"
      >View source on GitHub ↗</a>
      <a href={withBase('/gallery/gen-ai/')} class="underline underline-offset-4 hover:text-foreground">Gen-AI components →</a>
    </footer>
  </main>
</BaseLayout>
