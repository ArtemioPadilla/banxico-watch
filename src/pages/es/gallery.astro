---
import { withBase } from '@/lib/href';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n';

// Hreflang alternates — gallery landing
const site = 'https://artemiop.com';
const alternates = [
  { hreflang: 'en', href: `${site}/inceptor/gallery/` },
  { hreflang: 'es', href: `${site}/inceptor/es/gallery/` },
  { hreflang: 'x-default', href: `${site}/inceptor/gallery/` },
];
---

<BaseLayout title="inceptor — Galería de componentes" lang="es" alternates={alternates}>
  <main class="mx-auto max-w-6xl px-4 py-12">

    <section class="mb-16 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary">
        <span class="h-2 w-2 rounded-full bg-primary animate-pulse"></span>
        {t('es', 'nav.gallery')}
      </div>

      <h1
        class="mt-6 font-display text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
        style="view-transition-name: page-title"
      >
        {t('es', 'gallery.title')}
      </h1>

      <p class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground sm:text-lg">
        {t('es', 'gallery.tagline')}
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href={withBase('/gallery/')}
          class="group inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-primary/30"
        >
          {t('es', 'gallery.cta')} →
        </a>
        <a
          href={withBase('/es/')}
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-card/60 px-6 py-3 text-sm font-semibold text-foreground backdrop-blur transition-colors hover:border-primary/40 hover:bg-accent/50"
        >
          {t('es', 'nav.home')}
        </a>
        <a
          href={withBase('/')}
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-card/60 px-6 py-3 text-sm font-semibold text-foreground backdrop-blur transition-colors hover:border-primary/40 hover:bg-accent/50"
          hreflang="en"
          lang="en"
        >
          {t('es', 'nav.switchLanguage')}
        </a>
      </div>
    </section>

    <section class="rounded-2xl border border-border bg-card p-8 text-card-foreground">
      <h2 class="font-display text-2xl font-semibold">{t('es', 'gallery.bridgeHeading')}</h2>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
        {t('es', 'gallery.bridgeBody')}
      </p>
    </section>

  </main>
</BaseLayout>
