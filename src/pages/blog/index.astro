---
import { withBase } from '@/lib/href';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { flags } from '../../lib/flags';

type BlogEntry = CollectionEntry<'blog'>;

// Early redirect when the blog is disabled via feature flag.
if (!flags.blog) {
  return Astro.redirect(withBase('/'), 308);
}

const posts = (await getCollection('blog'))
  .filter((p: BlogEntry) => !p.data.draft)
  .sort((a: BlogEntry, b: BlogEntry) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Posts from this scaffold.">
  <main class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-foreground" style="view-transition-name: page-title">
        Blog
      </h1>
      <p class="mt-2 text-muted-foreground">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'}.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">
        No posts yet. Add a markdown file under <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">src/content/blog/</code>.
      </p>
    ) : (
      <ul class="space-y-6">
        {posts.map((post: BlogEntry) => (
          <li class="rounded-lg border border-border bg-card p-5">
            <a
              href={withBase(`/blog/${post.id}/`)}
              class="block group"
            >
              <h2 class="text-xl font-semibold text-foreground group-hover:underline">
                {post.data.title}
              </h2>
              <p class="mt-1 text-sm text-muted-foreground">{post.data.description}</p>
              <div class="mt-3 flex items-center gap-3 text-xs text-muted-foreground">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toISOString().slice(0, 10)}
                </time>
                {post.data.tags.length > 0 && (
                  <span class="flex gap-1.5">
                    {post.data.tags.map((tag: string) => (
                      <span class="rounded bg-muted px-1.5 py-0.5 font-mono">{tag}</span>
                    ))}
                  </span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>
